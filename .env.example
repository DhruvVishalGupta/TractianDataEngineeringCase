# Copy to .env and fill in real keys.

# Anthropic Claude — used by src/pipeline/claude_client.py for facility extraction.
# Model: claude-haiku-4-5-20251001 (configured in src/pipeline/config.py)
CLAUDE_API_KEY=

# Brave Search — used by src/pipeline/searcher.py for OSINT deep-link discovery
# and cross-source corroboration. Free tier is sufficient for 20 companies.
BRAVE_API_KEY=

# Firecrawl — used by src/pipeline/scraper.py to render JS-loaded pages as Markdown.
FIRECRAWL_API_KEY=
