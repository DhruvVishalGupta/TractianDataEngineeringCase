{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd src/dashboard && npm install",
  "buildCommand": "cd src/dashboard && npm run build",
  "outputDirectory": "src/dashboard/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!data/|assets/).*)", "destination": "/index.html" }
  ]
}
